{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "model": "openrouter/anthropic/claude-sonnet-4.6",
  "mcp": {
    "frame-mcp-servers": {
      "type": "local",
      "command": ["npx", "-y", "@frames-ag/frame", "serve", "datasets/mcp-servers"]
    },
    "frame-ai-promises": {
      "type": "local",
      "command": ["npx", "-y", "@frames-ag/frame", "serve", "datasets/ai-promises"]
    },
    "frame-ai-models": {
      "type": "local",
      "command": ["npx", "-y", "@frames-ag/frame", "serve", "datasets/ai-models"]
    }
  }
}
